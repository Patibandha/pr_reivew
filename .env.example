# Copy to `.env` and fill in locally. NEVER commit a real .env (see .gitignore).
# The agent runs fully offline with NONE of these set.

# Narration backend: "deterministic" (default) or "claude".
PR_AGENT_LLM=deterministic

# Only required when PR_AGENT_LLM=claude. Read from the environment at runtime;
# never hardcoded in source.
# ANTHROPIC_API_KEY=sk-ant-...
# PR_AGENT_MODEL=claude-sonnet-4-6
